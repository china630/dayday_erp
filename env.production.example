# Скопируйте в .env в корне репозитория (рядом с docker-compose.prod.yml):
#   cp env.production.example .env && nano .env
#
# Docker Compose подхватывает этот файл для подстановки переменных (в т.ч. COMPOSE_PROJECT_NAME).

# Имя проекта Compose — стабильное имя сети ${COMPOSE_PROJECT_NAME}_default (миграции, отладка).
COMPOSE_PROJECT_NAME=dayday_prod

# --- Postgres (обязательно задайте надёжный пароль) ---
POSTGRES_USER=dayday
POSTGRES_DB=dayday
POSTGRES_PASSWORD=

# --- Redis: только из .env; для сервиса redis из docker-compose.prod.yml ---
REDIS_URL=redis://redis:6379

# --- JWT (обязательно уникальные длинные секреты для production) ---
JWT_SECRET=
JWT_REFRESH_SECRET=

# --- Публичный фронт и CORS ---
PORT=3000
API_PUBLISH_PORT=4000
NEXT_PUBLIC_API_URL=http://api:4000
# Список origin через запятую, например: https://erp.example.com
CORS_ORIGINS=

# --- Опционально: Sentry ---
# SENTRY_DSN_API=
# NEXT_PUBLIC_SENTRY_DSN=

# --- Публикация портов на хост (по желанию смените или закройте файрволом) ---
# POSTGRES_PUBLISH_PORT=5432
# REDIS_PUBLISH_PORT=6379
