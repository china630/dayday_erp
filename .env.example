# Copy to .env in repo root for Prisma CLI / local tooling
#
# Инфраструктура на диске D (не C:):
#   D:\DockerData\dayday_erp\ — postgres, redis, storage, npm-cache, tmp (см. README там)
#   Корневой .npmrc задаёт npm cache на D; .vscode/settings.json — TEMP/TMP для терминала.
#   Docker Desktop: перенесите Disk image location на D, иначе образы останутся на C.

# Каталог данных Docker и локальных загрузок
DOCKER_DATA_ROOT=D:/DockerData/dayday_erp

DATABASE_URL="postgresql://dayday:dayday@127.0.0.1:5432/dayday?schema=public"

# JWT (обязательно для API; без них Nest не стартует)
JWT_SECRET=dev-jwt-secret-change-me
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# API (apps/api)
API_PORT=4000
# Liveness API (без JWT): канонический GET {NEXT_PUBLIC_API_URL}/api/health
# Legacy на том же хосте: GET /health — тот же JSON (балансировщики, старые мониторинги)
# Production: через запятую, точные Origin фронта (например https://app.example.com)
# CORS_ORIGINS=https://app.example.com
REDIS_URL="redis://localhost:6379"

# BullMQ: отключить ежемесячные SubscriptionInvoice (по умолчанию включено при REDIS)
# BILLING_MONTHLY_DISABLED=1

# Web (Next.js): подхватывается при `npm run dev:web` из корня через dotenv-cli
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# SMTP (отправка счетов и др.; без SMTP_HOST письма не уходят — API только логирует «Email would be sent to …»)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="DayDay ERP <no-reply@example.com>"
STORAGE_DRIVER=local
# Совпадает с томом проекта на D; при запуске API вне Docker — тот же путь
STORAGE_LOCAL_ROOT=D:/DockerData/dayday_erp/storage
# STORAGE_DRIVER=s3
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# Prisma seed: загрузить план счетов в демо-организацию
# SEED_DEMO_ORG=1

# VÖEN lookup (TaxService): без этого e-taxes может отдавать HTML — для стабильных E2E задайте 1
# TAX_LOOKUP_MOCK=1
