{
  "name": "dayday-erp",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm run dev:api\" \"wait-on tcp:127.0.0.1:4000 && npm run dev:web\"",
    "dev:api": "dotenv -e .env -- npm run start:dev -w @dayday/api",
    "dev:web": "dotenv -e .env -- npm run dev -w @dayday/web",
    "dev:web:clean": "dotenv -e .env -- npm run dev:clean -w @dayday/web",
    "restart:web": "npm run stop:next && dotenv -e .env -- npm run dev:clean -w @dayday/web",
    "restart:api": "npm run stop:api && dotenv -e .env -- npm run start:dev -w @dayday/api",
    "stop:next": "npx kill-port 3000",
    "stop:api": "npx kill-port 4000",
    "build": "npm run build -w @dayday/database && npm run build -w @dayday/api && npm run build -w @dayday/web",
    "db:generate": "dotenv -e .env -- npm run db:generate -w @dayday/database",
    "db:migrate": "dotenv -e .env -- npm run db:migrate -w @dayday/database",
    "db:migrate:deploy": "npm run db:migrate:deploy -w @dayday/database",
    "db:push": "dotenv -e .env -- npm run db:push -w @dayday/database",
    "db:execute": "dotenv -e .env -- npm exec -w @dayday/database prisma db execute --",
    "db:prisma": "dotenv -e .env -- npm exec -w @dayday/database prisma --",
    "db:seed": "npm run db:seed -w @dayday/database",
    "db:ifrs-demo-map": "dotenv -e .env -- npm run db:ifrs-demo-map -w @dayday/database",
    "db:studio": "dotenv -e .env -- npm run db:studio -w @dayday/database",
    "db:sync-i18n": "npm run db:sync-i18n -w @dayday/database",
    "db:dump-to-prod": "dotenv -e .env -- npm run docker-init:export -w @dayday/database",
    "db:wipe-tenant": "dotenv -e .env -- npx tsx packages/database/prisma/wipe-tenant-data.ts",
    "db:seed:tivi": "dotenv -e .env -- npm run db:seed:tivi -w @dayday/database",
    "db:prod-init": "npm run db:migrate:deploy && npm run db:seed && npm run db:sync-i18n && npm run db:prod-init -w @dayday/database",
    "db:apply-template:ifrs": "npm run db:apply-template:ifrs -w @dayday/database",
    "docker-init:export": "dotenv -e .env -- npm run docker-init:export -w @dayday/database",
    "docker-init:super-admin-hash": "dotenv -e .env -- npm run docker-init:super-admin-hash -w @dayday/database",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "i18n:audit": "npx tsx scripts/i18n-audit.ts",
    "screenshots:erp": "dotenv -e .env -- npm run capture --prefix tools/playwright-screenshots --"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0",
    "kill-port": "^2.0.1",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
