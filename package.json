{
  "name": "dayday-erp",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node ./scripts/free-dev-ports.mjs && concurrently -k -n api,web -c blue,magenta \"npm run dev:api\" \"wait-on tcp:127.0.0.1:4000 && npm run dev:web\"",
    "dev:api": "node ./scripts/free-dev-ports.mjs --api-only && dotenv -e .env -- npm run start:dev -w @dayday/api",
    "dev:web": "node ./scripts/free-dev-ports.mjs --web-only && node ./scripts/run-dev-web.mjs",
    "dev:web:clean": "node ./scripts/free-dev-ports.mjs --web-only && dotenv -e .env -- npm run dev:clean -w @dayday/web",
    "restart:web": "node ./scripts/stop-dev.mjs next && node ./scripts/free-dev-ports.mjs --web-only && dotenv -e .env -- npm run dev:clean -w @dayday/web",
    "restart:api": "node ./scripts/stop-dev.mjs api && node ./scripts/free-dev-ports.mjs --api-only && dotenv -e .env -- npm run start:dev -w @dayday/api",
    "stop:next": "node ./scripts/stop-dev.mjs next",
    "stop:api": "node ./scripts/stop-dev.mjs api",
    "build": "npm run build -w @dayday/database && npm run build -w @dayday/api && npm run build -w @dayday/web",
    "db:generate": "dotenv -e .env -- npm run db:generate -w @dayday/database",
    "db:migrate": "dotenv -e .env -- npm run db:migrate -w @dayday/database",
    "db:migrate:deploy": "dotenv -e .env -- npm run db:migrate:deploy -w @dayday/database",
    "db:push": "dotenv -e .env -- npm run db:push -w @dayday/database",
    "db:seed": "dotenv -e .env -- npm run db:seed -w @dayday/database",
    "db:ifrs-demo-map": "dotenv -e .env -- npm run db:ifrs-demo-map -w @dayday/database",
    "db:studio": "dotenv -e .env -- npm run db:studio -w @dayday/database",
    "db:sync-i18n": "npx dotenv-cli -e .env -- npm run db:sync-i18n -w @dayday/database",
    "db:wipe-tenant": "dotenv -e .env -- npx tsx packages/database/prisma/wipe-tenant-data.ts",
    "db:seed:tivi": "dotenv -e .env -- npm run db:seed:tivi -w @dayday/database",
    "docker-init:export": "dotenv -e .env -- npm run docker-init:export -w @dayday/database",
    "docker-init:super-admin-hash": "dotenv -e .env -- npm run docker-init:super-admin-hash -w @dayday/database",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "infra:d": "powershell -ExecutionPolicy Bypass -File scripts/ensure-infra-d.ps1",
    "infra:up": "npm run infra:d && npm run docker:up",
    "test:e2e:pdf": "node ./scripts/e2e-from-tests-pdf.mjs",
    "test:e2e:v4.1": "dotenv -e .env -- node ./scripts/e2e-v4.1.mjs",
    "test:e2e:billing": "dotenv -e .env -- node ./scripts/e2e-billing.mjs",
    "health:api": "node ./scripts/api-health-check.mjs",
    "health:api:legacy": "node ./scripts/api-health-check.mjs --legacy",
    "i18n:audit": "npx tsx scripts/i18n-audit.ts",
    "screenshots:erp": "dotenv -e .env -- npm run capture --prefix tools/playwright-screenshots --"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0",
    "kill-port": "^2.0.1",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
