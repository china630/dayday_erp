{
  "name": "@dayday/database",
  "version": "0.0.1",
  "private": true,
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./chart-seed": {
      "types": "./dist/chart-seed.d.ts",
      "default": "./dist/chart-seed.js"
    }
  },
  "scripts": {
    "postinstall": "prisma generate && npm run build:chart",
    "build:chart": "tsc -p tsconfig.chart.json",
    "build": "prisma generate && npm run build:chart",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:ifrs-demo-map": "tsx prisma/ifrs-demo-mapping.ts",
    "db:studio": "prisma studio",
    "db:sync-i18n": "tsx prisma/sync-translation-overrides-from-resources.ts",
    "db:sync-i18n:prune": "tsx prisma/sync-translation-overrides-from-resources.ts --prune",
    "db:audit-i18n-overrides": "tsx prisma/audit-translation-overrides.ts",
    "db:audit-i18n-overrides:fix": "tsx prisma/audit-translation-overrides.ts --fix",
    "db:seed:tivi": "tsx prisma/seed-tivi.ts",
    "db:prod-init": "tsx prisma/prod-init.ts",
    "db:apply-template:ifrs": "tsx prisma/apply-template-ifrs-mapping.ts",
    "db:migrate:nas-names": "tsx prisma/data-migrate-nas-account-names.ts",
    "db:seed:nas-templates": "tsx prisma/seed-nas-accounts.ts",
    "docker-init:export": "tsx prisma/docker-init/export-seed-data.ts",
    "docker-init:super-admin-hash": "tsx prisma/docker-init/export-super-admin-hash.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.6.1",
    "pg": "^8.16.3",
    "prisma": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0"
  }
}
