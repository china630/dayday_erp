generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                           String                        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                         String
  taxId                        String                        @map("tax_id")
  currency                     String                        @default("AZN")
  /// *
  ///    * Юридический адрес (профиль организации, v19.0).
  legalAddress                 String?                       @map("legal_address")
  /// *
  ///    * Контактный телефон организации.
  phone                        String?
  /// *
  ///    * Руководитель (ФИО / должность в свободной форме для печати).
  directorName                 String?                       @map("director_name")
  /// *
  ///    * Логотип (URL в объектном хранилище после upload).
  logoUrl                      String?                       @map("logo_url")
  /// *
  ///    * Метод оценки запасов для COGS: средневзвешенная (AVCO) или FIFO по движениям.
  valuationMethod              InventoryValuationMethod      @default(AVCO) @map("valuation_method")
  settings                     Json                          @default("{}")
  subscriptionPlan             String?                       @map("subscription_plan")
  billingStatus                BillingStatus                 @default(ACTIVE) @map("billing_status")
  createdAt                    DateTime                      @default(now()) @map("created_at")
  updatedAt                    DateTime                      @updatedAt @map("updated_at")
  /// *
  ///    * Секрет URL вебхука Direct Banking: POST /api/public/banking/webhook/:secret
  bankWebhookSecret            String?                       @unique @map("bank_webhook_secret")
  /// *
  ///    * Владелец организации для биллинга (v10.2).
  ownerId                      String?                       @map("owner_id") @db.Uuid
  /// *
  ///    * Включённые модули (slug) на уровне организации — денормализация для биллинга v10.2;
  ///    * источник правды для гейтинга остаётся OrganizationSubscription.customConfig / activeModules.
  activeModules                String[]                      @default([]) @map("active_modules")
  /// *
  ///    * Bytes stored in object storage for this org (logos, PDFs); quota STORAGE (v23.0).
  storageUsedBytes             BigInt                        @default(0) @map("storage_used_bytes")
  deletedAt                    DateTime?                     @map("deleted_at") @db.Timestamptz(6)
  holdingId                    String?                       @map("holding_id") @db.Uuid
  /// Профиль онбординга NAS: полный коммерческий план или упрощённый (малый бизнес).
  coaTemplateProfile           CoaTemplateProfile            @default(COMMERCIAL_FULL) @map("coa_template_profile")
  isDeleted                    Boolean                       @default(false) @map("is_deleted")
  absenceTypes                 AbsenceType[]
  absences                     Absence[]
  accessRequests               AccessRequest[]
  accountMappings              AccountMapping[]
  accountBalances              AccountBalance[]
  accounts                     Account[]
  advanceReports               AdvanceReport[]
  auditLogs                    AuditLog[]
  bankStatementLines           BankStatementLine[]
  bankStatements               BankStatement[]
  billingInvoiceItems          BillingInvoiceItem[]
  cashDesks                    CashDesk[]
  cashFlowItems                CashFlowItem[]
  cashOrders                   CashOrder[]
  counterparties               Counterparty[]
  departments                  Department[]
  bankAccountsOrg              OrganizationBankAccount[]
  digitalSignatureLogs         DigitalSignatureLog[]
  employees                    Employee[]
  fixedAssetDepreciationMonths FixedAssetDepreciationMonth[]
  fixedAssets                  FixedAsset[]
  inventoryAdjustments         InventoryAdjustment[]
  inventoryAuditLines          InventoryAuditLine[]
  inventoryAudits              InventoryAudit[]
  invoiceItems                 InvoiceItem[]
  paymentAllocations           PaymentAllocation[]
  invoicePayments              InvoicePayment[]
  invoices                     Invoice[]
  journalEntries               JournalEntry[]
  invites                      OrganizationInvite[]
  memberships                  OrganizationMembership[]
  organizationModules          OrganizationModule[]
  subscription                 OrganizationSubscription?
  holding                      Holding?                      @relation(fields: [holdingId], references: [id])
  owner                        User?                         @relation("OrganizationOwner", fields: [ownerId], references: [id])
  paymentOrders                PaymentOrder[]
  taxDeclarationExports        TaxDeclarationExport[]
  payrollRuns                  PayrollRun[]
  salaryRegistries             SalaryRegistry[]
  bankPaymentDrafts            BankPaymentDraft[]
  ifrsMappingRules             IfrsMappingRule[]
  payrollSlips                 PayrollSlip[]
  productRecipes               ProductRecipe[]
  products                     Product[]
  stockItems                   StockItem[]
  stockMovements               StockMovement[]
  timesheets                   Timesheet[]
  transactions                 Transaction[]
  warehouses                   Warehouse[]
  warehouseBins                WarehouseBin[]

  @@index([ownerId])
  @@index([holdingId, id])
  @@index([holdingId])
  @@index([coaTemplateProfile])
  @@map("organizations")
}

/// Профиль копирования глобального NAS в локальный план организации.
enum CoaTemplateProfile {
  COMMERCIAL_FULL
  COMMERCIAL_SMALL
}

/// Глобальный справочник NAS (платформа): один код — одна строка; профили Small/Full через массив.
model TemplateAccount {
  id              String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code            String               @unique
  nameAz          String               @map("name_az")
  nameRu          String               @map("name_ru")
  nameEn          String               @map("name_en")
  accountType     AccountType          @map("account_type")
  parentCode      String?              @map("parent_code")
  cashProfile     String?              @map("cash_profile")
  sortOrder       Int                  @default(0) @map("sort_order")
  isDeprecated    Boolean              @default(false) @map("is_deprecated")
  /// В каких профилях онбординга счёт входит (полный коммерческий и/или малый бизнес).
  templateGroups  CoaTemplateProfile[] @default([]) @map("template_groups")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  accounts        Account[]

  @@index([code])
  @@map("template_accounts")
}

model AccountBalance {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  accountId      String      @map("account_id") @db.Uuid
  ledgerType     LedgerType  @default(NAS) @map("ledger_type")
  balanceDate    DateTime    @map("balance_date") @db.Date
  debitBalance   Decimal     @default(0) @map("debit_balance") @db.Decimal(19, 4)
  creditBalance  Decimal     @default(0) @map("credit_balance") @db.Decimal(19, 4)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  account        Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, accountId, ledgerType, balanceDate])
  @@index([organizationId, ledgerType, balanceDate])
  @@map("account_balances")
}

/// *
///  * Банковские счета организации (реквизиты для документов и интеграций), 1:N к Organization.
model OrganizationBankAccount {
  id             String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  bankName       String                 @map("bank_name")
  accountNumber  String                 @map("account_number")
  currency       OrgBankAccountCurrency
  iban           String?
  swift          String?
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salaryRegistries SalaryRegistry[]

  @@index([organizationId])
  @@map("organization_bank_accounts")
}

/// *
///  * Глобальный справочник компаний по VÖEN: асинхронно наполняется из профиля организации и карточек контрагентов (Smart-fill).
model GlobalCompanyDirectory {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  taxId        String   @unique @map("tax_id")
  name         String
  legalAddress String?  @map("legal_address")
  phone        String?  @map("phone")
  directorName String?  @map("director_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("global_company_directory")
}

/// *
///  * Подключённые модули по организации: цена на момент включения и политика отмены (pro-rata / конец периода).
model OrganizationModule {
  organizationId String       @map("organization_id") @db.Uuid
  moduleKey      String       @map("module_key")
  priceSnapshot  Decimal      @map("price_snapshot") @db.Decimal(12, 2)
  activatedAt    DateTime     @default(now()) @map("activated_at")
  pendingDeactivation Boolean @default(false) @map("pending_deactivation")
  /// *
  ///    * Заполнено при отключении: автопродление снято, доступ до accessUntil.
  cancelledAt    DateTime?    @map("cancelled_at")
  /// *
  ///    * Конец текущего оплаченного периода (UTC), после — модуль снимается с activeModules.
  accessUntil    DateTime?    @map("access_until") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([organizationId, moduleKey])
  @@map("organization_modules")
}

/// *
///  * Актуальные цены конструктора: база, модули, квоты (v10.2). Сидируется по умолчанию.
model Pricing {
  id        String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key       String      @unique
  kind      PricingKind
  name      String
  amountAzn Decimal     @map("amount_azn") @db.Decimal(12, 2)
  /// *
  ///    * Для квот: размер блока (напр. 10 сотрудников, 5 GB, 500 инвойсов); для Foundation/модуля — null.
  unitSize  Int?        @map("unit_size")
  sortOrder Int         @default(0) @map("sort_order")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("pricing")
}

/// *
///  * Единый счёт платформы на Owner-аккаунт (TZ §14.8 / v12.3). Не путать с Invoice (продажи).
model SubscriptionInvoice {
  id             String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// *
  ///    * Плательщик / владелец портфеля (owner user).
  userId         String                    @map("user_id") @db.Uuid
  /// *
  ///    * Итог по счёту (AZN).
  amount         Decimal                   @db.Decimal(12, 2)
  status         SubscriptionInvoiceStatus
  /// *
  ///    * Дата выставления / учёта.
  date           DateTime                  @db.Date
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  /// *
  ///    * Расчётный период (месяц и т.п.).
  periodStart    DateTime?                 @map("period_start") @db.Timestamptz(6)
  periodEnd      DateTime?                 @map("period_end") @db.Timestamptz(6)
  billingPeriod  String?                   @map("billing_period")
  /// *
  ///    * Готовый PDF в объектном хранилище (опционально).
  pdfLink        String?                   @map("pdf_link")
  /// *
  ///    * Связь с заказом оплаты (шлюз); счёт выставляется на owner, услуга — по organization в строках.
  paymentOrderId String?                   @unique @map("payment_order_id") @db.Uuid
  items          BillingInvoiceItem[]
  paymentOrder   PaymentOrder?             @relation(fields: [paymentOrderId], references: [id])
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, billingPeriod])
  @@map("subscription_invoices")
}

/// *
///  * Строки платформенного счёта: разбивка по организациям (VÖEN) — TZ §14.8.4.
model BillingInvoiceItem {
  id                    String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  subscriptionInvoiceId String              @map("subscription_invoice_id") @db.Uuid
  organizationId        String              @map("organization_id") @db.Uuid
  description           String
  amount                Decimal             @db.Decimal(12, 2)
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionInvoice   SubscriptionInvoice @relation(fields: [subscriptionInvoiceId], references: [id], onDelete: Cascade)

  @@index([subscriptionInvoiceId])
  @@index([organizationId])
  @@map("billing_invoice_items")
}

/// *
///  * Связь пользователь ↔ организация (роль в рамках организации).
model OrganizationMembership {
  userId         String       @map("user_id") @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  role           UserRole
  joinedAt       DateTime     @default(now()) @map("joined_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, organizationId])
  @@index([organizationId])
  @@map("organization_memberships")
}

/// *
///  * Запрос на вступление в организацию (поиск по VÖEN).
model AccessRequest {
  id              String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId  String              @map("organization_id") @db.Uuid
  requesterId     String              @map("requester_id") @db.Uuid
  status          AccessRequestStatus @default(PENDING)
  message         String?
  createdAt       DateTime            @default(now()) @map("created_at")
  decidedAt       DateTime?           @map("decided_at")
  decidedByUserId String?             @map("decided_by_user_id") @db.Uuid
  decidedBy       User?               @relation("AccessRequestDecider", fields: [decidedByUserId], references: [id])
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requester       User                @relation("AccessRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([requesterId])
  @@map("access_requests")
}

/// *
///  * Приглашение по email в организацию.
model OrganizationInvite {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  email           String
  role            UserRole
  status          InviteStatus @default(PENDING)
  invitedByUserId String?      @map("invited_by_user_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at")
  decidedAt       DateTime?    @map("decided_at")
  invitedBy       User?        @relation("InviteInviter", fields: [invitedByUserId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
  @@map("organization_invites")
}

/// *
///  * Подразделение (иерархия: parentId).
model Department {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  name           String
  parentId       String?       @map("parent_id") @db.Uuid
  managerId      String?       @map("manager_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  manager        Employee?     @relation("DepartmentManager", fields: [managerId], references: [id])
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Department?   @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children       Department[]  @relation("DepartmentHierarchy")
  jobPositions   JobPosition[]
  transactions   Transaction[]

  @@index([organizationId])
  @@index([parentId])
  @@map("departments")
}

/// *
///  * Штатная единица (должность) в подразделении.
model JobPosition {
  id           String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  departmentId String     @map("department_id") @db.Uuid
  name         String
  totalSlots   Int        @map("total_slots")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  /// *
  ///    * Нижняя граница вилки оклада по штатке (AZN), справочно.
  minSalary    Decimal    @map("min_salary") @db.Decimal(19, 4)
  /// *
  ///    * Верхняя граница вилки оклада по штатке (AZN), справочно.
  maxSalary    Decimal    @map("max_salary") @db.Decimal(19, 4)
  employees    Employee[]
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([departmentId])
  @@map("job_positions")
}

/// *
///  * Заказ на оплату подписки (шлюз Pasha Bank / mock).
model PaymentOrder {
  id                  String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId      String               @map("organization_id") @db.Uuid
  amountAzn           Decimal              @map("amount_azn") @db.Decimal(12, 2)
  currency            String               @default("AZN")
  status              PaymentOrderStatus   @default(PENDING)
  /// *
  ///    * pasha_bank | mock
  provider            String               @default("pasha_bank")
  providerTxnId       String?              @map("provider_txn_id")
  monthsApplied       Int                  @default(1) @map("months_applied")
  description         String               @default("")
  idempotencyKey      String?              @unique @map("idempotency_key")
  metadata            Json                 @default("{}")
  createdAt           DateTime             @default(now()) @map("created_at")
  paidAt              DateTime?            @map("paid_at")
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionInvoice SubscriptionInvoice?

  @@index([organizationId])
  @@index([status])
  @@map("payment_orders")
}

/// *
///  * Подписка организации (1:1). Slugs модулей: production, ifrs, banking_pro и др.; v8.1 — customConfig.modules (конструктор).
model OrganizationSubscription {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String           @unique @map("organization_id") @db.Uuid
  tier           SubscriptionTier
  expiresAt      DateTime?        @map("expires_at")
  activeModules  String[]         @default([]) @map("active_modules")
  isTrial        Boolean          @default(false) @map("is_trial")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  /// *
  ///    * Принудительная блокировка доступа (супер-админ).
  isBlocked      Boolean          @default(false) @map("is_blocked")
  /// *
  ///    * Конструктор тарифа (v8.1): JSON с полями `modules` (массив slug), опционально `preset`, `quotas`.
  ///    * При непустом `modules` гейтинг модулей в первую очередь по этому массиву (см. TZ §14).
  customConfig   Json?            @map("custom_config")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_subscriptions")
}

/// *
///  * Ключ-значение: тарифы, лимиты, системные сообщения (Super-Admin).
model SystemConfig {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

/// *
///  * Каталог платных модулей: месячная цена (поле pricePerMonth = «priceMonthly» в API-описаниях).
model PricingModule {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key           String   @unique
  name          String
  pricePerMonth Decimal  @map("price_per_month") @db.Decimal(12, 2)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("pricing_modules")
}

/// *
///  * Именованный пакет модулей со скидкой (Paket Yaradıcısı).
model PricingBundle {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String
  discountPercent Decimal  @default(0) @map("discount_percent") @db.Decimal(5, 2)
  moduleKeys      Json     @map("module_keys")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("pricing_bundles")
}

/// *
///  * Переопределение строк i18n поверх статических файлов фронта.
model TranslationOverride {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  locale    String
  key       String
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([locale, key])
  @@index([locale])
  @@map("translation_overrides")
}

/// *
///  * Инвентаризационная опись: строки в `items` (JSON) — warehouseId, productId, factQty, inventoryAccountCode и др.
model InventoryAudit {
  id             String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  date           DateTime             @db.Date
  status         InventoryAuditStatus
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  warehouseId    String               @map("warehouse_id") @db.Uuid
  lines          InventoryAuditLine[]
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse      Warehouse            @relation(fields: [warehouseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organizationId])
  @@index([organizationId, warehouseId, date], map: "inventory_audits_org_wh_date_idx")
  @@map("inventory_audits")
}

model Warehouse {
  id                   String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId       String           @map("organization_id") @db.Uuid
  name                 String
  location             String           @default("")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  inventoryAccountCode String           @default("201") @map("inventory_account_code")
  inventory_adjustments InventoryAdjustment[]
  inventory_audits     InventoryAudit[]
  invoices             Invoice[]
  stockItems           StockItem[]
  stockMovements       StockMovement[]
  bins                 WarehouseBin[]
  users                User[]
  organization         Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("warehouses")
}

model StockItem {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  warehouseId    String       @map("warehouse_id") @db.Uuid
  productId      String       @map("product_id") @db.Uuid
  binId          String?      @map("bin_id") @db.Uuid
  quantity       Decimal      @default(0) @db.Decimal(19, 4)
  averageCost    Decimal      @default(0) @map("average_cost") @db.Decimal(19, 4)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  bin            WarehouseBin? @relation(fields: [binId], references: [id], onDelete: SetNull)
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([organizationId, warehouseId, productId])
  @@index([organizationId, warehouseId])
  @@map("stock_items")
}

model StockMovement {
  id              String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId  String              @map("organization_id") @db.Uuid
  warehouseId     String              @map("warehouse_id") @db.Uuid
