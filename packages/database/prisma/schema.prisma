  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Account?              @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       Account[]             @relation("AccountHierarchy")
  balances       AccountBalance[]
  journalEntries JournalEntry[]

  @@unique([organizationId, code, ledgerType])
  @@index([organizationId, createdAt])
  @@index([organizationId, currency])
  @@index([organizationId, ledgerType])
  @@index([chartEntryId])
  @@index([templateAccountId])
  @@map("accounts")
}

/// *
///  * Сопоставление счёта NAS ↔ IFRS для теневых проводок (Multi-GAAP).
model AccountMapping {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  nasAccountId   String       @map("nas_account_id") @db.Uuid
  ifrsAccountId  String       @map("ifrs_account_id") @db.Uuid
  /// *
  ///    * Коэффициент пересчёта суммы строки NAS → IFRS (1 = 1:1).
  ratio          Decimal      @default(1) @db.Decimal(19, 8)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  ifrsAccount    Account      @relation("AccountMappingIfrs", fields: [ifrsAccountId], references: [id])
  nasAccount     Account      @relation("AccountMappingNas", fields: [nasAccountId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, nasAccountId])
  @@index([organizationId])
  @@map("account_mappings")
}

