  warehouse       Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([organizationId, warehouseId, documentDate, createdAt])
  @@index([organizationId, productId, documentDate, createdAt])
  @@map("stock_movements")
