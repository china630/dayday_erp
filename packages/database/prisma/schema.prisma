  description     String            @default("")
  formula         AbsencePayFormula
  maxCalendarDays Int?              @map("max_calendar_days")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  absences     Absence[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("absence_types")
}

model CashDesk {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  employeeId     String?  @map("employee_id") @db.Uuid
  currencies     String[] @default([])
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  employee     Employee?    @relation(fields: [employeeId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cashOrders   CashOrder[]

  @@index([employeeId])
  @@index([organizationId])
  @@map("cash_desks")
}

model CashFlowItem {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  code           String
  name           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  bankStatementLines BankStatementLine[]
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cashOrders         CashOrder[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("cash_flow_items")
}

model ChartOfAccountsEntry {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  templateGroup TemplateGroup @default(COMMERCIAL) @map("template_group")
  code         String
  nameAz       String      @map("name_az")
  nameRu       String      @map("name_ru")
  nameEn       String      @map("name_en")
  accountType  AccountType @map("account_type")
  /// Код родителя в том же справочнике (иерархия NAS); null — корень.
  parentCode   String?     @map("parent_code")
  cashProfile  String?     @map("cash_profile")
  sortOrder    Int         @default(0) @map("sort_order")
  isDeprecated Boolean     @default(false) @map("is_deprecated")
  createdAt    DateTime    @default(now()) @map("created_at")
  accounts     Account[]

  @@unique([templateGroup, code])
  @@map("chart_of_accounts_entries")
}

model GlobalCounterparty {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  taxId          String         @unique @map("tax_id")
  name           String
  legalAddress   String?        @map("legal_address")
  vatStatus      Boolean?       @map("vat_status")
  updatedAt      DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  counterparties Counterparty[]

  @@map("global_counterparties")
}

model HoldingMembership {
  userId    String            @map("user_id") @db.Uuid
  holdingId String            @map("holding_id") @db.Uuid
  role      HoldingAccessRole @default(VIEWER)
  createdAt DateTime          @default(now()) @map("created_at")

  holding Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, holdingId])
  @@index([holdingId])
  @@map("holding_memberships")
}

model Holding {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String    @unique
  ownerId      String    @map("owner_id") @db.Uuid
  baseCurrency String    @default("AZN") @map("base_currency")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  memberships   HoldingMembership[]
  owner         User                @relation(fields: [ownerId], references: [id])
  organizations Organization[]

  @@index([ownerId])
  @@map("holdings")
}

model InventoryAuditLine {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  inventoryAuditId String   @map("inventory_audit_id") @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  systemQty        Decimal  @map("system_qty") @db.Decimal(19, 4)
  factQty          Decimal  @map("fact_qty") @db.Decimal(19, 4)
  costPrice        Decimal  @map("cost_price") @db.Decimal(19, 4)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  inventoryAudit InventoryAudit @relation(fields: [inventoryAuditId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inventory_audit_lines_audit_fkey")
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inventory_audit_lines_org_fkey")
  product        Product        @relation(fields: [productId], references: [id], onUpdate: NoAction, map: "inventory_audit_lines_product_fkey")

  @@unique([inventoryAuditId, productId], map: "inventory_audit_lines_audit_product_uidx")
  @@index([organizationId, inventoryAuditId], map: "inventory_audit_lines_org_audit_idx")
  @@index([organizationId, productId], map: "inventory_audit_lines_org_product_idx")
  @@map("inventory_audit_lines")
}

/// *
///  * Документ физической инвентаризации / списания / оприходования (черновик → проведение).
model InventoryAdjustment {
  id             String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String                     @map("organization_id") @db.Uuid
  warehouseId    String                     @map("warehouse_id") @db.Uuid
  date           DateTime                   @db.Date
  status         InventoryAdjustmentStatus  @default(DRAFT)
  reason         String                     @default("")
  docType        InventoryAdjustmentDocType @map("doc_type")
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")
  lines          InventoryAdjustmentLine[]
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse      Warehouse                  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([organizationId, warehouseId, date])
  @@index([organizationId, status])
  @@map("inventory_adjustments")
}

model InventoryAdjustmentLine {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  adjustmentId     String   @map("adjustment_id") @db.Uuid
  productId        String   @map("product_id") @db.Uuid
  expectedQuantity Decimal  @map("expected_quantity") @db.Decimal(19, 4)
  actualQuantity   Decimal  @map("actual_quantity") @db.Decimal(19, 4)
  deltaQuantity    Decimal  @map("delta_quantity") @db.Decimal(19, 4)
  unitCost         Decimal  @default(0) @map("unit_cost") @db.Decimal(19, 4)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  adjustment       InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  product          Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([adjustmentId, productId])
  @@index([productId])
  @@map("inventory_adjustment_lines")
}

