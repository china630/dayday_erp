  nameAz         String                @map("name_az")
  /// Русскоязычное наименование (NAS / MMÜS).
  nameRu         String                @map("name_ru")
  /// Англоязычное наименование (NAS / MMÜS).
  nameEn         String                @map("name_en")
  type           AccountType
  parentId       String?               @map("parent_id") @db.Uuid
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  /// *
  ///    * Валюта учёта остатка по счёту (AZN, USD, EUR). Для переоценки — не-AZN.
  currency       String                @default("AZN")
  /// *
  ///    * Книга: NAS (основной план) или IFRS (параллельный учёт).
  ledgerType     LedgerType            @default(NAS) @map("ledger_type")
  chartEntryId   String?               @map("chart_entry_id") @db.Uuid
  templateAccountId String?            @map("template_account_id") @db.Uuid
