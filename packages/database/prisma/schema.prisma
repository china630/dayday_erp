model Transaction {
  id                           String                        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId               String                        @map("organization_id") @db.Uuid
  date                         DateTime                      @db.Date
  reference                    String?
  description                  String?
  createdAt                    DateTime                      @default(now()) @map("created_at")
  updatedAt                    DateTime                      @updatedAt @map("updated_at")
  /// *
  ///    * true — курс/суммы в документе зафиксированы (подтверждено бухгалтерией);
  ///    * false — «плавающий» курс до подтверждения.
  isFinal                      Boolean                       @default(false) @map("is_final")
  /// *
  ///    * Закрытый период: транзакция не должна корректироваться задним числом
  isLocked                     Boolean                       @default(false) @map("is_locked")
  counterpartyId               String?                       @map("counterparty_id") @db.Uuid
  /// Аналитика ЦФО: расходы/прочие проводки, привязанные к департаменту.
  departmentId                 String?                       @map("department_id") @db.Uuid
  advanceReportsPosted         AdvanceReport?                @relation("AdvanceReportPostedTx")
  cashOrdersLinked             CashOrder[]                   @relation("CashOrderLinkedTx")
  cashOrdersPosted             CashOrder[]                   @relation("CashOrderPostedTx")
  fixedAssetDepreciationMonths FixedAssetDepreciationMonth[]
  invoicePayments              InvoicePayment[]
  paymentAllocations           PaymentAllocation[]
  journalEntries               JournalEntry[]
  payrollRuns                  PayrollRun[]
  counterparty                 Counterparty?                 @relation(fields: [counterpartyId], references: [id])
  department                   Department?                   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  organization                 Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([organizationId, isFinal, date], map: "transactions_org_status_period_idx")
  @@index([counterpartyId])
  @@index([organizationId, createdAt])
  @@index([organizationId, date, isLocked])
  @@index([departmentId])
  @@map("transactions")
}

model JournalEntry {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  transactionId  String       @map("transaction_id") @db.Uuid
  accountId      String       @map("account_id") @db.Uuid
  debit          Decimal      @default(0) @db.Decimal(19, 4)
  credit         Decimal      @default(0) @db.Decimal(19, 4)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  ledgerType     LedgerType   @default(NAS) @map("ledger_type")
  account        Account      @relation(fields: [accountId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction    Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([organizationId, transactionId])
  @@index([organizationId, accountId])
  @@index([accountId], map: "journal_entries_account_id_idx")
  @@index([organizationId, ledgerType, transactionId], map: "journal_entries_org_period_status_ledger_idx")
  @@index([organizationId, createdAt])
  @@index([organizationId, ledgerType])
  @@map("journal_entries")
}

model Counterparty {
  id             String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String                    @map("organization_id") @db.Uuid
  name           String
  taxId          String                    @map("tax_id")
  kind           CounterpartyKind
  role           CounterpartyRole          @default(CUSTOMER)
  legalForm      CounterpartyLegalForm     @default(LLC) @map("legal_form")
  address        String?
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  email          String?
  /// Плательщик НДС (учётный статус контрагента)
